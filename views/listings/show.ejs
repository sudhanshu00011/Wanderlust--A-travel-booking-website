<% layout("/layouts/boilerplate") %>

<div class="row mt-4">
    <div class="col-8 offset-2">

        <h3 class="text-center mb-4"><%= listing.title %></h3>

        <!-- Main Listing Content - No border -->
        <div class="mb-4">
            <img src="<%= listing.image.url %>" 
                 class="show-img mb-3" 
                 alt="<%= listing.title %>"
                 style="width: 100%; height: 420px; object-fit: cover; border-radius: 12px;">

            <div class="p-3 bg-light rounded-3">
                <p class="fs-5 mb-3">
                    <%= listing.description %>
                </p>
                <p class="fs-4 fw-bold text-success">
                    ₹ <%= listing.price.toLocaleString("en-IN") %> / night
                </p>
                <p class="text-muted fs-5">
                    <%= listing.location %>, <%= listing.country %>
                </p>
            </div>
        </div>

        <!-- Edit & Delete Buttons -->
        <div class="d-flex gap-2 mb-4">
            <a href="/listings/<%= listing._id %>/edit" 
               class="btn btn-warning px-4">Edit</a>
            
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
                <button type="submit" class="btn btn-danger px-4">Delete</button>
            </form>
        </div>

        <hr>

        <!-- Review Form -->
        <h4 class="mb-3">Leave a Review</h4>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="rating" class="form-label">Rating</label>
                <input type="range" min="1" max="5" class="form-range" id="rating" name="review[rating]">
            </div>
            <div class="mb-3">
                <label for="comment" class="form-label">Comment</label>
                <textarea name="review[comment]" class="form-control" rows="4" required></textarea>
            </div>
            <button type="submit" class="btn btn-dark">Submit</button>
        </form>

    </div>
</div>