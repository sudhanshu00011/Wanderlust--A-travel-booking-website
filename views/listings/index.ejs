<% layout("/layouts/boilerplate") %>

    <body>
        <h3>All Listings</h3>
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
            <% for (let listing of allListings) { %>
                <button onclick="window.location.href='/listings/<%= listing._id %>'" class="listing-link">
                <div class="card col listing-card">
                    <img src="<%= listing.image.url %>" class="card-img-top index-img" alt="listing_image" style="height :20rem">
                    <div class="card-img-overlay"><%=listing.title%></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b>
                                <%= listing.title %>
                            </b>
                            <br>&#8377; <%=listing.price.toLocaleString("en-IN")%>/night
                        </p>
                        <a href="#" class="btn btn-primary">Go somewhere</a>
                    </div>

                </div>
            </button>
            <% } %>
        </div>

    </body>